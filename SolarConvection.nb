Cell[CellGroupData[{

Cell["2.4  Spherical harmonics as basis functions", "Subsection",ExpressionUUID->"dac22e70-1b87-413d-ae1f-a8770985e6f8"],

Cell[TextData[{
 "Spherical harmonics ",
 Cell[BoxData[
  SubsuperscriptBox["Y", "l", "m"]],ExpressionUUID->
  "7f8054b3-a193-4742-9928-5314f75bd143"],
 "(\[Theta], \[Phi]) are the natural Fourier basis on the sphere. Every \
square-integrable field on the sphere expands as"
}], "Text",ExpressionUUID->"c8bbae12-7335-4759-9e6a-1fe8a10f5b68"],

Cell[BoxData[
 FormBox[
  RowBox[{"\[Omega]", 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}], "=", 
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"l", "=", "0"}], "\[Infinity]"], 
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"m", "=", 
     RowBox[{"-", "l"}]}], "l"], 
   SubsuperscriptBox["\[Omega]", "l", "m"], " ", 
   SubsuperscriptBox["Y", "l", "m"], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], 
  TraditionalForm]], "DisplayFormula",
 TextAlignment->Center,ExpressionUUID->"71a3c913-d2c9-4b86-9a14-f5937dd5ce7c"],

Cell["\<\
with \[Theta] the colatitude and \[Phi] the longitude. Each harmonic \
factorises into an associated Legendre function in latitude and a complex \
exponential in longitude:\
\>", "Text",ExpressionUUID->"9aedd264-5161-4023-92a6-8e58cbce5c23"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubsuperscriptBox["Y", "l", "m"], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}], "=", 
   SubsuperscriptBox["N", "l", "m"], " ", 
   SubsuperscriptBox["P", "l", "m"], 
   RowBox[{"(", 
    RowBox[{"cos", " ", "\[Theta]"}], ")"}], " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "m", " ", "\[Phi]"}]]}], 
  TraditionalForm]], "DisplayFormula",
 TextAlignment->Center,ExpressionUUID->"76066b27-be02-46e2-9f01-0e5cf3691b7a"],

Cell["The two integer indices have direct physical meaning:", "Text",ExpressionUUID->"8f19c102-448e-4617-9ad1-81384d693cad"],

Cell[TextData[{
 "The degree l sets the total horizontal wavenumber \[Dash] the number of \
nodal circles on the sphere. Large l = small spatial scale. The \
characteristic angular wavelength is 2\[Pi]/",
 Cell[BoxData[
  SqrtBox[
   RowBox[{"l", 
    RowBox[{"(", 
     RowBox[{"l", "+", "1"}], ")"}]}]]],ExpressionUUID->
  "5a9441b9-ac6e-4784-a232-3f238c876775"],
 "."
}], "Item",ExpressionUUID->"576f3a07-25bf-4d08-8b4b-0309358c39af"],

Cell["\<\
The order m sets how much of that structure is in longitude: m nodal \
meridians. Sectoral harmonics (m = l) are the striped, banana-like patterns \
aligned with the rotation axis; zonal harmonics (m = 0) are pure latitude \
bands.\
\>", "Item",ExpressionUUID->"1d08f92a-a8a6-4cc1-8e83-47cb0a118349"],

Cell["\<\
The gallery below shows how (l, m) sets a spatial scale and shape. Large m \
produces elongated, axis-aligned stripes. These resemble the \
\[OpenCurlyDoubleQuote]banana cells\[CloseCurlyDoubleQuote] of rotating \
convection, but the resemblance is superficial \[Dash] it is a property of \
the harmonic itself, not evidence that the 2-D model organises the flow this \
way.\
\>", "Text",ExpressionUUID->"e6ed002e-741e-4d5a-b7e8-772915930859"],

Cell[CellGroupData[{

Cell["\<\
(* each row uses valid orders m = 0, l/2, l for its degree l *)
Grid[Table[
  Table[
   SphericalPlot3D[1, {\[Theta], 0, Pi}, {\[Phi], 0, 2 Pi},
    ColorFunction -> Function[{x, y, z, \[Theta], \[Phi], r},
      ColorData[\"TemperatureMap\"][
       Rescale[Re[SphericalHarmonicY[l, m, \[Theta], \[Phi]]], {-0.45, \
0.45}]]],
    ColorFunctionScaling -> False, Mesh -> None, PlotPoints -> 45,
    Boxed -> False, Axes -> False, ImageSize -> 165,
    PlotLabel -> Row[{\"l=\", l, \", m=\", m}]],
   {m, {0, l/2, l}}],
  {l, {4, 8}}],
 Frame -> All, FrameStyle -> LightGray]\
\>", "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"22a2cfec-3f3b-47fa-b4ad-451bc489755f"],

