 TextData[{"Simulation code: ", 
   StyleBox[
   "config_v6.py, simulate_v6.py, visualize_v6.py", FontFamily -> "Courier", 
    FontSize -> 11], 
   " \[Dash] 2-D barotropic vorticity solver (pyshtools) with a 3-D \
