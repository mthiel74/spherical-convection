Cell["\<\
The convective envelope occupies only the outer 29% of the Sun by radius but, \
because of the geometry, a substantial fraction of its volume. Our simulation \
models the dynamics on a representative spherical surface within this \
envelope.\
\>", "Text",ExpressionUUID->"1df56389-a308-4f7b-9051-87396527ba48"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["2.  The Mathematics", "Section",ExpressionUUID->"9ff4901c-119e-410a-9670-795225e47b37"],

Cell["\<\
The full problem \[Dash] compressible, magnetised, rotating convection in a \
stratified sphere \[Dash] is formidable. The barotropic vorticity equation is \
the simplest model that still captures the essence of rotation-dominated, \
quasi-two-dimensional turbulence on a sphere. It describes the evolution of a \
single scalar field, the vertical (radial) vorticity, on a spherical surface.\
\
\>", "Text",ExpressionUUID->"dd66eed8-72be-4dbb-8f0a-92464ffedf8b"],

Cell[CellGroupData[{

Cell["2.1  From momentum to vorticity", "Subsection",ExpressionUUID->"7a845a40-f44f-4504-98b5-8d8cc762a180"],

Cell[TextData[{
 "Start from the momentum equation for a thin, incompressible fluid layer on \
a rotating sphere. Horizontal velocity ",
 Cell[BoxData[
  OverscriptBox["u", "\[RightVector]"]],ExpressionUUID->
  "ac92f928-9986-4404-a8fc-136bbf638680"],
 " obeys"
}], "Text",ExpressionUUID->"3540a531-c938-4f26-b40c-b9875c0b03f8"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox["\[PartialD]", 
    RowBox[{"\[PartialD]", "t"}]], 
   OverscriptBox["u", "\[RightVector]"], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      OverscriptBox["u", "\[RightVector]"], "\[CenterDot]", "\[Del]"}], ")"}], 
    OverscriptBox["u", "\[RightVector]"]}], "+", 
   RowBox[{"f", " ", 
    OverscriptBox["z", "^"], "\[Cross]", 
    OverscriptBox["u", "\[RightVector]"]}], "=", 
   RowBox[{"-", 
    FractionBox["1", "\[Rho]"], 
    RowBox[{"\[Del]", "p"}]}], "+", 
   OverscriptBox["\[ScriptCapitalF]", "\[RightVector]"]}], 
  TraditionalForm]], "DisplayFormula",
 TextAlignment->Center,ExpressionUUID->"68afda46-d35f-4e77-818f-94321d87d69f"],

Cell[TextData[{
 "Here f = 2\[CapitalOmega] sin\[Phi] is the Coriolis parameter (\
\[CapitalOmega] the rotation rate, \[Phi] latitude) and ",
 Cell[BoxData[
  OverscriptBox["\[ScriptCapitalF]", "\[RightVector]"]],ExpressionUUID->
  "8d33dd6b-76ac-4a2c-8cbd-d8d53443ea99"],
 " collects friction and forcing. Taking the vertical component of the curl, ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox["z", "^"], "\[CenterDot]", 
   RowBox[{"\[Del]", "\[Cross]", 
    RowBox[{"(", "\[CenterDot]", ")"}]}]}]],ExpressionUUID->
  "440016fb-0fe1-48a6-8d59-d93d66a5352a"],
 ", and using incompressibility (\[Del]\[CenterDot]",
 Cell[BoxData[
  OverscriptBox["u", "\[RightVector]"]],ExpressionUUID->
  "0b1864d7-3e98-42ab-b560-6612d790ef46"],
 " = 0) eliminates the pressure term entirely and yields the evolution of the \
relative vertical vorticity \[Omega] = ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox["z", "^"], "\[CenterDot]", 
   RowBox[{
    RowBox[{"\[Del]", "\[Cross]"}], 
    OverscriptBox["u", "\[RightVector]"]}]}]],ExpressionUUID->
  "babbaa3b-a93f-4312-af18-173cb4c57672"],
 ":"
}], "Text",ExpressionUUID->"e650f635-800d-4554-97e9-1727e5390387"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox[
    RowBox[{"\[PartialD]", "\[Omega]"}], 
    RowBox[{"\[PartialD]", "t"}]], "+", 
   RowBox[{"J", 
    RowBox[{"(", 
     RowBox[{"\[Psi]", ",", " ", "\[Omega]", "+", "f"}], ")"}]}], "=", 
   RowBox[{"-", "\[Nu]", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"-", 
       SuperscriptBox["\[Del]", "2"]}], ")"}], "4"], "\[Omega]"}], "-", 
   RowBox[{"\[Mu]", " ", "\[Omega]"}], "+", "F"}], 
  TraditionalForm]], "DisplayFormula",
 TextAlignment->Center,ExpressionUUID->"5b3b7972-1754-494d-ae41-16c01c9c3110"],

Cell["\<\
This is the equation the simulation integrates. Reading the terms left to \
right:\
\>", "Text",ExpressionUUID->"b88b41f3-d390-4491-abcf-5d377af58eca"],

Cell["\[PartialD]\[Omega]/\[PartialD]t \[Dash] local rate of change of \
vorticity.", "Item",ExpressionUUID->"282fb0b9-51a7-468f-9559-0f19f0825de1"],

Cell["\<\
J(\[Psi], \[Omega]+f) \[Dash] nonlinear advection of absolute vorticity by \
the flow (the Jacobian, defined below). This is the term that makes the \
problem turbulent.\
\>", "Item",ExpressionUUID->"bf989154-4e28-44e7-ba47-0936d23908e7"],

Cell[TextData[{
 "-\[Nu] ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{"-", 
     RowBox[{"\[Del]", "\[Cross]", "\[Del]"}]}], ")"}], "4"]],ExpressionUUID->
  "48d4a688-d883-48a3-983f-df56aa05dd7e"],
 "\[Omega] \[Dash] ",
 Cell[BoxData[
  SuperscriptBox["\[Del]", "8"]],ExpressionUUID->
  "b4e32618-784d-48ca-a0df-27ee4c484b46"],
 " hyperviscosity, a scale-selective drain that only removes the very \
smallest scales (Section 4)."
}], "Item",ExpressionUUID->"720ceee2-37b7-4251-bb8e-8ff9a94de14d"],

Cell["\<\
-\[Mu] \[Omega] \[Dash] uniform linear (Rayleigh) drag that removes energy \
from the largest scales so the turbulence reaches a statistically steady \
state.\
\>", "Item",ExpressionUUID->"2594295d-87e1-49d0-9646-62bc6e7fcfe3"],

Cell["\<\
F \[Dash] stochastic (white-in-time) forcing that injects vorticity in a \
chosen band of scales. It is an imposed stirring, a kinematic stand-in for \
the stirring convective plumes would provide; it is NOT buoyancy and does not \
arise from any instability. The forced scale is put in by hand through the \
forcing band, not selected by the dynamics.\
\>", "Item",ExpressionUUID->"710df45c-f1c1-4862-886f-4e2e9e5dc2b9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
2.2  Streamfunction and the vorticity\[Dash]streamfunction relation\
\>", "Subsection",ExpressionUUID->"ca2d11f0-d1c9-4117-9426-cb8bbfe82670"],

Cell["\<\
Because the horizontal flow is non-divergent, it can be written in terms of a \
single scalar streamfunction \[Psi]. Velocity is the skew-gradient of \[Psi], \
and vorticity is its Laplacian:\
\>", "Text",ExpressionUUID->"bdc526d8-08cf-4dd9-81fe-305e8be2ae47"],

Cell[BoxData[
 FormBox[
  RowBox[{"\[Omega]", "=", 
   RowBox[{
    SuperscriptBox["\[Del]", "2"], "\[Psi]"}]}], 
  TraditionalForm]], "DisplayFormula",
 TextAlignment->Center,ExpressionUUID->"db8aabc0-9705-4f0a-822c-c242fcc7e1b2"],

Cell[TextData[{
 "Inverting this relation \[Dash] recovering \[Psi] from \[Omega] \[Dash] is \
a Poisson problem, ",
 Cell[BoxData[
  SuperscriptBox["\[Del]", "2"]],ExpressionUUID->
  "7e4f18de-9fb8-4eee-bd7b-798509e60275"],
 "\[Psi] = \[Omega]. On the sphere it is trivial in spectral space, as we \
will see, because spherical harmonics diagonalise the Laplacian."
}], "Text",ExpressionUUID->"1732e6d5-fd89-4416-8292-e373a192c56e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2.3  The Coriolis parameter and planetary vorticity", "Subsection",ExpressionUUID->"94c7c703-5011-42d3-9164-a5af9fde1b98"],

Cell["\<\
The background planetary vorticity \[Dash] the vorticity of the solid-body \
rotation of the sphere itself \[Dash] is f = 2\[CapitalOmega] sin\[Phi]. It \
vanishes at the equator and is largest at the poles:\
\>", "Text",ExpressionUUID->"5184ccd0-3991-4c6d-b9f0-b340464b0c22"],

Cell[BoxData[
 FormBox[
  RowBox[{"f", "=", 
   RowBox[{"2", " ", "\[CapitalOmega]", " ", "sin", "\[Phi]"}]}], 
  TraditionalForm]], "DisplayFormula",
 TextAlignment->Center,ExpressionUUID->"83fac1b6-3243-4e61-a9ba-dea58e4fa453"],

Cell[TextData[{
 "Its gradient, the famous \[Beta] = df/dy, is the restoring mechanism for \
Rossby waves and the reason large-scale geophysical turbulence is \
anisotropic. In the spectral code, f is exactly a single spherical-harmonic \
mode: since ",
 Cell[BoxData[
  SubsuperscriptBox["Y", "1", "0"]],ExpressionUUID->
  "957b8178-0a41-4ddc-9918-d38570eada6d"],
 " \[Proportional] sin\[Phi], the field 2\[CapitalOmega] sin\[Phi] is \
proportional to ",
 Cell[BoxData[
  SubsuperscriptBox["Y", "1", "0"]],ExpressionUUID->
  "9ff14f5e-5ea6-47c1-b833-78d8cafa3448"],
 " alone \[Dash] which is exactly how simulate_v6.py stores it. But \
\[OpenCurlyDoubleQuote]proportional to ",
 Cell[BoxData[
  SubsuperscriptBox["Y", "1", "0"]],ExpressionUUID->
  "062091a3-2b81-44c5-a34b-329dd7a62a55"],
 "\[CloseCurlyDoubleQuote] hides a constant whose value depends entirely on \
the harmonic normalisation \[Dash] and getting that constant wrong is exactly \
the bug that v5 shipped."
}], "Text",ExpressionUUID->"3135ed80-797d-4064-b018-c7140d019763"],

Cell[CellGroupData[{

Cell["2.3.1  A normalisation cautionary tale (the v5 Coriolis bug)", \
"Subsubsection",ExpressionUUID->"d1faf4e9-cf05-4b43-8aaf-723713ad7f30"],

Cell[TextData[{
 "The solver (pyshtools) uses REAL, 4\[Pi]-normalised spherical harmonics. In \
that convention the l=1, m=0 harmonic is ",
 Cell[BoxData[
  SubsuperscriptBox["Y", "1", "0"]],ExpressionUUID->
  "4b8a8b83-e4fe-4499-808b-7029d79bef8c"],
 " = ",
 Cell[BoxData[
  SqrtBox["3"]],ExpressionUUID->"98d40d8d-d7a9-4857-8185-4b71a0553919"],
 " cos\[Theta] = ",
 Cell[BoxData[
  SqrtBox["3"]],ExpressionUUID->"d609f395-53f5-4930-ad7f-920bed06b453"],
 " sin\[Phi]; its peak value at the pole is ",
 Cell[BoxData[
  SqrtBox["3"]],ExpressionUUID->"954b8394-cf03-49e7-bbfb-cf28f508c827"],
 ", NOT the ",
 Cell[BoxData[
  SqrtBox[
   RowBox[{
    RowBox[{"3", "/", "4"}], "\[Pi]"}]]],ExpressionUUID->
  "30fb0c3a-012a-479e-b1b1-2161bc777469"],
 " of the more familiar orthonormal (unit-normalised) convention. To \
represent f = 2\[CapitalOmega] sin\[Phi] you need the coefficient c with c\
\[ThinSpace]",
 Cell[BoxData[
  SqrtBox["3"]],ExpressionUUID->"56cb1928-2e01-4067-b798-31bd2b36b969"],
 " sin\[Phi] = 2\[CapitalOmega] sin\[Phi], i.e. c = 2\[CapitalOmega]/",
 Cell[BoxData[
  SqrtBox["3"]],ExpressionUUID->"cd24c751-ef2b-41cf-8ec7-a593ba0bc936"],
 "."
}], "Text",ExpressionUUID->"c5c5ef50-a97c-4c73-ac84-28c812a64f57"],

Cell[TextData[{
 "v5 instead used c = 2\[CapitalOmega]",
 Cell[BoxData[
  SqrtBox[
   RowBox[{"4", 
    RowBox[{"\[Pi]", "/", "3"}]}]]],ExpressionUUID->
  "41571c14-58cd-402a-b83c-879c85737e7d"],
 " \[Dash] the coefficient that is correct only for UNIT-normalised harmonics \
\[Dash] while feeding it to 4\[Pi]-normalised ones. Because the \
4\[Pi]-normalised harmonics are larger by a factor ",
 Cell[BoxData[
  SqrtBox[
   RowBox[{"4", "\[Pi]"}]]],ExpressionUUID->
  "ffadae39-f2e0-4079-bc78-87fa0212168d"],
 " \[TildeTilde] 3.545, the planetary vorticity came out too large by exactly \
that factor. The intended \[CapitalOmega] = 40 behaved like an effective \
\[CapitalOmega] \[TildeTilde] 142, and f at the pole was \[TildeTilde] 283 \
instead of 80. v6 uses c = 2\[CapitalOmega]/",
 Cell[BoxData[
  SqrtBox["3"]],ExpressionUUID->"74c24239-da23-40b2-8e64-596b8f2e401b"],
 ", giving f(pole) = 2\[CapitalOmega] = 80 exactly. The lesson: a spectral \
coefficient is meaningless until you state the normalisation of the basis it \
multiplies."
}], "Text",ExpressionUUID->"1ac88159-a67c-4aea-898e-f78fb07b8010"],

Cell[CellGroupData[{

Cell["\<\
With[{\[CapitalOmega] = 40},
 Association[
  \"Y10 peak (4\[Pi]-norm, at pole)\" -> Sqrt[3] // N,
  \"v6 coefficient  2\[CapitalOmega]/Sqrt[3]\" -> 2 \[CapitalOmega]/Sqrt[3] \
// N,
  \"=> f(pole) = coeff*peak\" -> (2 \[CapitalOmega]/Sqrt[3]) Sqrt[3] // N,
  \"v5 coefficient  2\[CapitalOmega]Sqrt[4\[Pi]/3]\" -> 2 \[CapitalOmega] \
Sqrt[4 Pi/3] // N,
  \"=> v5 effective f(pole)\" -> 2 \[CapitalOmega] Sqrt[4 Pi/3] Sqrt[3] // N,
  \"overstatement factor  Sqrt[4\[Pi]]\" -> Sqrt[4 Pi] // N]]
(* f(pole) should be 80; v5 delivered ~283, i.e. \
Sqrt[4\[Pi]]\[TildeTilde]3.545x too large. *)\
\>", "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"a5ba5148-c518-4ab1-a167-a6421058ff54"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Y10 peak (4\[Pi]-norm, at pole)\"\>", "\[Rule]", 
    "1.7320508075688772`"}], ",", 
   RowBox[{"\<\"v6 coefficient  2\[CapitalOmega]/Sqrt[3]\"\>", "\[Rule]", 
    "46.188021535170066`"}], ",", 
   RowBox[{"\<\"=> f(pole) = coeff*peak\"\>", "\[Rule]", "80.`"}], ",", 
   RowBox[{"\<\"v5 coefficient  2\[CapitalOmega]Sqrt[4\[Pi]/3]\"\>", "\[Rule]",
     "163.73227327143815`"}], ",", 
   RowBox[{"\<\"=> v5 effective f(pole)\"\>", "\[Rule]", 
    "283.5926161448825`"}], ",", 
   RowBox[{"\<\"overstatement factor  Sqrt[4\[Pi]]\"\>", "\[Rule]", 
    "3.5449077018110318`"}]}], "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.992517339495384*^9},
 CellLabel->"Out[2]=",ExpressionUUID->"2758d299-c850-4c64-83ab-a73d32c97848"]
}, Open  ]],

Cell["\<\
Visualise f on the sphere. It is antisymmetric about the equator: positive \
(red) in the northern hemisphere, negative (blue) in the south.\
\>", "Text",ExpressionUUID->"4a5bd5e4-4b84-481a-ba5e-51cf79e6fb90"],

Cell[CellGroupData[{

Cell["\<\
SphericalPlot3D[1, {\[Theta], 0, Pi}, {\[Phi], 0, 2 Pi},
 ColorFunction -> Function[{x, y, z, \[Theta], \[Phi], r},
   (* f \[Proportional] sin(latitude) = cos(\[Theta]) *)
   ColorData[\"TemperatureMap\"][(Cos[\[Theta]] + 1)/2]],
 ColorFunctionScaling -> False, Mesh -> None, PlotPoints -> 60,
 Boxed -> False, Axes -> False, ImageSize -> 380,
 PlotLabel -> Style[\"Coriolis parameter  f = 2\[CapitalOmega] sin\[Phi]\", \
13, Bold]]\
\>", "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"be1a461c-8ed9-4fa6-adb8-02e2ff4b774c"],

