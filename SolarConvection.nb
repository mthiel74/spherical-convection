          "]], {}}, {}},
      Boxed->False,
      DisplayFunction->Identity,
      FaceGridsStyle->Automatic,
      ImagePadding->Automatic,
      ImageSize->165,
      Lighting->"Neutral",
      Method->{
       "DefaultGraphicsInteraction" -> {
         "Version" -> 1.2, "TrackMousePosition" -> {True, False}, 
